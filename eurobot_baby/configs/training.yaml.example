# Copiare in configs/training.yaml sul pod e adattare max_steps dopo ogni rebuild.

batch_size: 4
gradient_accumulation_steps: 4
learning_rate: 3.0e-4
weight_decay: 0.01
warmup_steps: 150
# max_steps: dopo rebuild, calcolare come ceil(N_train_chunks / effective_batch_per_step) * num_epochs
# effective_batch_per_step = batch_size * gradient_accumulation_steps  (es. 4*4=16)
# Esempio: 1155955 chunks, 2 epoche -> ceil(1155955/16)*2 = 144496
max_steps: 144496
max_seq_len: 512
save_every: 3000
eval_every: 1500
eval_batches: 20
seed: 42
use_fp16: true
gradient_clip: 1.0

data_train: data/processed/train.jsonl
data_val: data/processed/val.jsonl
tokenizer_dir: models/tokenizer
checkpoint_dir: models/checkpoints
